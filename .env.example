# Evolution en Railway — guía completa: deploy/evolution/RAILWAY.md

# URL pública de Carrizo (Netlify, ngrok en local, o dominio propio)
# En Netlify: https://tu-sitio.netlify.app (sin barra final)
NEXT_PUBLIC_APP_URL=

# Proveedor: evolution (QR, sin Facebook) | meta (API oficial)
WHATSAPP_PROVIDER=evolution

# Gemini — bot de ventas (mismo motor en WhatsApp y CRM)
# Educación editable: config/enderxon-gemini-education.md
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Evolution API (docker compose up -d)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=carrizo-evolution-dev
EVOLUTION_INSTANCE=enderxon

# Meta WhatsApp Cloud API (alternativa oficial)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=carrizo_webhook_secreto
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DISPLAY_PHONE=+56 9 9181 3566

# Marketing (opcional)
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_TOKEN=
NEXT_PUBLIC_GA4_ID=
GA4_API_SECRET=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_API_TOKEN=
